Para que esto pase, debemos usar expresiones. Por ejemplo: width - (i * sepx) hace que el punto avance de derecha a izquierda.

int cant = 10;
int sepx, sepy;
void setup() {
  size(800, 600);
  sepx = width/cant;
  sepy = height/cant;
}

void draw() {
  background(255);
  for (int i = 0; i<cant; i++) {
    line(0, i*sepy, i*sepx, height);
